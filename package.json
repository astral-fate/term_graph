{
  "name": "audit-ai",
  "version": "1.0.0",
  "description": "Audit AI — glossary + local FastAPI compliance audit (same pipeline as Gradio reference).",
  "main": "index.js",
  "scripts": {
    "build": "node build.js",
    "dev": "node build.js && wrangler pages dev dist --port 8788",
