# Copy to `.env` in this folder or in the repo root (same parent as `backend/`).
# Get a key: https://build.nvidia.com/ → API Keys, or your NVIDIA NIM dashboard.

NVIDIA_API_KEY=

# Optional — when set, routes require Authorization: Bearer <secret>, OR (private HF + gateway token)
# Authorization: Bearer <hf_read_token> plus header X-Audit-Secret: Bearer <AUDIT_API_SECRET>
# AUDIT_API_SECRET=

# Optional: Hugging Face token if the rubric must be downloaded privately.
# HF_TOKEN=

# Browser front-end must be allowed here or CORS blocks fetch("http://127.0.0.1:8788/...").
# Defaults cover common dev ports; for production set explicit origins only:
# CORS_ORIGINS=https://yourapp.example,https://www.yourapp.example
# Disable permissive localhost regex in production:
# CORS_LOCAL_REGEX=0
