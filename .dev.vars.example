# Copy to .dev.vars (gitignored). From repo root:
#   node build.js
#   npx wrangler pages dev
# Uses wrangler.toml (dist + ./functions). Plain static servers will 404 on /api/v1/chat/completions.
#
# Cloudflare production: set the same name in Pages → Settings → Environment variables.

NVIDIA_API_KEY=replace_with_your_nvapi_token
