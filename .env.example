# Copy this file to `.env` in the same folder and fill in real values.
# Never commit `.env` (it stays ignored by git).
#
# Create an API token: Cloudflare Dashboard → My Profile → API Tokens → Create Token
#   Use a template with "Edit Cloudflare Workers" or custom with "Account — Cloudflare Pages — Edit"
#
CLOUDFLARE_API_TOKEN=replace_with_your_api_token
CLOUDFLARE_ACCOUNT_ID=replace_with_your_account_id
